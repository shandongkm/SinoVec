# SinoVec 环境变量配置示例
# 复制为 .env 并填入真实值

# 数据库连接
MEMORY_DB_HOST=127.0.0.1
MEMORY_DB_PORT=5433
MEMORY_DB_NAME=memory
MEMORY_DB_USER=sinovec
MEMORY_DB_PASS=your_strong_password_here

# 可选：HuggingFace 代理（国内需要）
# HF_HUB_PROXY=http://127.0.0.1:7890

# 服务配置
MEMORY_API_HOST=127.0.0.1
MEMORY_API_PORT=18793

# 会话目录（用于 extract_memories.py）
SESSIONS_DIR=~/.openclaw/agents/main/sessions

# Ollama LLM 配置（可选，用于查询扩展和结果重排）
# 不安装 Ollama 时自动降级（仅向量+BM25 检索）
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=qwen2.5:7b
# OLLAMA_FALLBACK_MODELS=qwen2.5:3b
