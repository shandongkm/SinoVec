# SinoVec 环境配置示例
# 复制为 .env 并填入真实值

# 数据库连接
MEMORY_DB_HOST=127.0.0.1
MEMORY_DB_PORT=5433
MEMORY_DB_NAME=memory
MEMORY_DB_USER=sinovec
MEMORY_DB_PASS=your_password_here

# HuggingFace 代理 (国内需要)
# HF_HUB_PROXY=http://127.0.0.1:7890

# 服务配置
MEMORY_API_HOST=127.0.0.1
MEMORY_API_PORT=18793

# 会话目录（用于 extract_memories.py 和 session_indexer_sinovec.py）
SESSIONS_DIR=~/.openclaw/agents/main/sessions

# 去重阈值
MEM_COSINE_DIST_MERGE=0.15
